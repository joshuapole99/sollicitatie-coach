# ── Supabase (NEW — required for auth + database) ──────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Anthropic (existing) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Upstash KV (existing — tier + usage tracking) ─────────────
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your-upstash-token

# ── LemonSqueezy (existing — payments) ────────────────────────
APP_MODE=live   # set to "test" for testing without real payments

# Live checkout URLs
LS_CHECKOUT_PLUS_LIVE=https://sollicitatie-coach.lemonsqueezy.com/checkout/buy/YOUR_PLUS_VARIANT
LS_CHECKOUT_PRO_LIVE=https://sollicitatie-coach.lemonsqueezy.com/checkout/buy/YOUR_PRO_VARIANT

# Test checkout URLs (only needed when APP_MODE=test)
LS_CHECKOUT_PLUS_TEST=
LS_CHECKOUT_PRO_TEST=

# Variant IDs (must match the plan being sold)
LS_VARIANT_PLUS=your-plus-variant-id
LS_VARIANT_PRO=your-pro-variant-id

LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ── Formspree (existing — review submissions) ─────────────────
FORMSPREE_URL=https://formspree.io/f/your-form-id

# ── Site URL (for auth redirects) ─────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sollicitatie-coach.vercel.app
